APP_NAME="ResumeFit"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=resumefit
DB_USERNAME=resumefit_user
DB_PASSWORD=resumefit_password

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

FASTAPI_BASE_URL=http://ai-service:8000

# Gemini API Key - Get yours from https://ai.google.dev/
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-1.5-flash